<?xml version="1.0" encoding="UTF-8"?>

<?import eu.iamgio.animated.binding.AnimationSettings?>
<?import eu.iamgio.animated.binding.value.AnimatedIntValueLabel?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.*?>
<BorderPane prefHeight="680.0" prefWidth="1100.0" style="-fx-background-color: #1a6b3a;" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="scalatro.view.FxController">

    <!-- ============================================================ -->
    <!-- LEFT COLUMN: Blind info / Goal score / Round score / Chips×Mult -->
    <!-- ============================================================ -->
    <left>
        <VBox alignment="TOP_CENTER" maxWidth="230.0" minWidth="230.0" prefWidth="230.0" spacing="16.0"
              style="-fx-background-color: #2c5f45; -fx-border-color: #1a4a30; -fx-border-width: 0 2 0 0;">
            <padding>
                <Insets bottom="30" left="15" right="15" top="30"/>
            </padding>

            <!-- Current blind name -->
            <Label text="SMALL BLIND" textFill="#f5c842">
                <font>
                    <Font name="System Bold" size="15.0"/>
                </font>
            </Label>

            <Label fx:id="roundNumLabel" textFill="#f5c842">
                <font>
                    <Font name="System Bold" size="15.0"/>
                </font>
            </Label>

            <!-- Score to beat -->
            <VBox alignment="CENTER" spacing="5.0" styleClass="score-box">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12"/>
                </padding>
                <Label text="Score at least" textFill="#aaaaaa">
                    <font>
                        <Font size="12.0"/>
                    </font>
                </Label>
                <Label fx:id="goalLabel" text="300" textFill="white">
                    <font>
                        <Font name="System Bold" size="28.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- Current round score -->
            <VBox alignment="CENTER" spacing="5.0" styleClass="score-box">
                <padding>
                    <Insets bottom="12" left="12" right="12" top="12"/>
                </padding>
                <Label text="Round Score" textFill="#aaaaaa">
                    <font>
                        <Font size="12.0"/>
                    </font>
                </Label>
                <Label fx:id="roundScoreLabel" text="0" textFill="#f5e642">
                    <font>
                        <Font name="System Bold" size="28.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- Push chips×mult to the bottom -->
            <Region VBox.vgrow="ALWAYS"/>
            <!-- fx:id="handLabel" preserved from the original for controller compat -->
            <Label fx:id="handLabel" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="26.0"/>
                </font>
            </Label>
            <Label fx:id="handLevelLabel" textFill="#aaaaaa">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>

            <!-- Chips × Mult -->
            <HBox alignment="CENTER" spacing="10.0">
                <!-- Blue chips rectangle -->
                <StackPane>
                    <Rectangle arcHeight="12.0" arcWidth="12.0" fill="#2a82d8" height="60.0" width="75.0"/>
                    <AnimatedIntValueLabel fx:id="chipsLabel" textFill="WHITE" value="0">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                        <settings>
                            <AnimationSettings curve="EASE_OUT" duration="200ms"/>
                        </settings>
                    </AnimatedIntValueLabel>
                </StackPane>

                <Label text="×" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="26.0"/>
                    </font>
                </Label>

                <!-- Red mult rectangle -->
                <StackPane>
                    <Rectangle arcHeight="12.0" arcWidth="12.0" fill="#d84a4a" height="60.0" width="75.0"/>
                    <AnimatedIntValueLabel fx:id="multLabel" textFill="WHITE" value="0">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                        <settings>
                            <AnimationSettings curve="EASE_OUT" duration="200ms"/>
                        </settings>
                    </AnimatedIntValueLabel>
                </StackPane>
            </HBox>

            <!-- Hands left / Discards left counters -->
            <HBox alignment="CENTER" spacing="10.0">
                <VBox alignment="CENTER" spacing="4.0" styleClass="mini-stat-box">
                    <padding>
                        <Insets bottom="8" left="10" right="10" top="8"/>
                    </padding>
                    <Label text="Hands" textFill="#aaaaaa">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>
                    <Label fx:id="handsRemainingLabel" text="3" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="20.0"/>
                        </font>
                    </Label>
                </VBox>
                <VBox alignment="CENTER" spacing="4.0" styleClass="mini-stat-box">
                    <padding>
                        <Insets bottom="8" left="10" right="10" top="8"/>
                    </padding>
                    <Label text="Discards" textFill="#aaaaaa">
                        <font>
                            <Font size="11.0"/>
                        </font>
                    </Label>
                    <Label fx:id="discardsRemainingLabel" text="3" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="20.0"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </left>

    <!-- ============================================================ -->
    <!-- CENTER: Detected hand name + level                            -->
    <!-- ============================================================ -->
    <center>
        <VBox alignment="BOTTOM_CENTER" spacing="18.0">
            <padding>
                <Insets bottom="30" left="20" right="20" top="20"/>
            </padding>
            <children>
                <VBox prefHeight="200.0" prefWidth="100.0">
                    <children>

                        <!-- ==================================================== -->
                        <!-- Row 1: card fan (left/center) + deck (right, offset  -->
                        <!-- down so it sits apart from the hand, per mockup)      -->
                        <!-- ==================================================== -->
                        <HBox alignment="CENTER" spacing="30.0">
                            <children>
                                <VBox alignment="CENTER" spacing="18.0">
                                    <children>
                                        <!-- The 8 selectable card slots -->
                                        <HBox alignment="CENTER" spacing="5.0">
                                            <ToggleButton fx:id="cardBtn1" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card1" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn2" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card2" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn3" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card3" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn4" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card4" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn5" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card5" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn6" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card6" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn7" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card7" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                            <ToggleButton fx:id="cardBtn8" styleClass="card-button">
                                                <graphic>
                                                    <ImageView fx:id="card8" fitHeight="125.0" fitWidth="85.0"
                                                               pickOnBounds="true" preserveRatio="true"/>
                                                </graphic>
                                            </ToggleButton>
                                        </HBox>

                                        <!-- Row 2: Play Hand / Sort Hand / Discard, aligned to the card fan -->
                                        <HBox alignment="CENTER" spacing="20.0">
                                            <children>
                                                <Button fx:id="playButton" alignment="CENTER" prefWidth="200.0"
                                                        styleClass="play-button" text="Play">
                                                    <font>
                                                        <Font name="System Bold" size="15.0"/>
                                                    </font>
                                                </Button>

                                                <VBox alignment="CENTER" spacing="6.0" styleClass="sort-panel">
                                                    <padding>
                                                        <Insets bottom="8" left="14" right="14" top="6"/>
                                                    </padding>
                                                    <Label text="Sort Hand" textFill="#aaaaaa">
                                                        <font>
                                                            <Font name="System Bold" size="11.0"/>
                                                        </font>
                                                    </Label>
                                                    <HBox alignment="CENTER" spacing="8.0">
                                                        <Button fx:id="sortRankButton" styleClass="sort-button"
                                                                text="Rank">
                                                            <font>
                                                                <Font name="System Bold" size="12.0"/>
                                                            </font>
                                                        </Button>
                                                        <Button fx:id="sortSuitButton" styleClass="sort-button"
                                                                text="Suit">
                                                            <font>
                                                                <Font name="System Bold" size="12.0"/>
                                                            </font>
                                                        </Button>
                                                    </HBox>
                                                </VBox>

                                                <Button fx:id="discardButton" alignment="CENTER" prefWidth="200.0"
                                                        styleClass="discard-button" text="Discard">
                                                    <font>
                                                        <Font name="System Bold" size="15.0"/>
                                                    </font>
                                                </Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <!-- Deck: same row, but visually offset lower/right -->
                                <VBox alignment="CENTER" spacing="6.0" translateY="35.0">
                                    <ImageView fx:id="deckImage" fitHeight="125.0" fitWidth="85.0" preserveRatio="true">
                                        <image>
                                            <Image url="@decks/Red_Deck.png"/>
                                        </image>
                                    </ImageView>
                                    <Label fx:id="deckLabel" text="Deck" textFill="WHITE">
                                        <font>
                                            <Font name="System Bold" size="14.0"/>
                                        </font>
                                    </Label>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
