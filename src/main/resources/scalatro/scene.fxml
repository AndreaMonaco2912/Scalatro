<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="1000.0"
            style="-fx-background-color: #1a6b3a;"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="scalatro.ScalatroController">

    <!-- ============================================================ -->
    <!-- LEFT COLUMN: Gray sidebar with Score + Chips × Mult           -->
    <!-- ============================================================ -->
    <left>
        <VBox alignment="TOP_CENTER" prefWidth="220.0" spacing="25.0"
              style="-fx-background-color: #5a5a5a;">
            <padding>
                <Insets top="40" right="15" bottom="30" left="15"/>
            </padding>

            <!-- Big white bold label at the top of the column -->
            <Label fx:id="scoreLabel" text="SCORE" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="32.0"/>
                </font>
            </Label>

            <!-- Blue rectangle  ×  Red rectangle, white labels inside -->
            <HBox alignment="CENTER" spacing="12.0">

                <!-- Blue rectangle (chips) -->
                <StackPane>
                    <Rectangle arcHeight="12.0" arcWidth="12.0"
                               fill="#2a82d8" height="60.0" width="75.0"/>
                    <Label fx:id="chipsLabel" text="0" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                </StackPane>

                <!-- White × between the two rectangles -->
                <Label text="X" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="26.0"/>
                    </font>
                </Label>

                <!-- Red rectangle (mult) -->
                <StackPane>
                    <Rectangle arcHeight="12.0" arcWidth="12.0"
                               fill="#d84a4a" height="60.0" width="75.0"/>
                    <Label fx:id="multLabel" text="0" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="24.0"/>
                        </font>
                    </Label>
                </StackPane>
            </HBox>
        </VBox>
    </left>

    <!-- ============================================================ -->
    <!-- BOTTOM AREA: 8 cards + deck, each with a label underneath     -->
    <!-- ============================================================ -->
    <bottom>
        <HBox alignment="BOTTOM_CENTER" spacing="40.0">
            <padding>
                <Insets top="20" right="40" bottom="40" left="40"/>
            </padding>

            <!-- The 8 selectable cards + label under them -->
            <VBox alignment="CENTER" spacing="10.0">
                <HBox alignment="CENTER" spacing="8.0">
                    <ImageView fx:id="card1" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/2_of_Clubs.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card2" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/3_of_Clubs.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card3" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Jack_of_Spades.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card4" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Queen_of_Hearts.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card5" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Ace_of_Hearts.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card6" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Jack_of_Diamonds.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card7" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Jack_of_Diamonds.png"/></image>
                    </ImageView>
                    <ImageView fx:id="card8" fitHeight="130.0" fitWidth="90.0" preserveRatio="true" pickOnBounds="true">
                        <image><Image url="@cards/Jack_of_Diamonds.png"/></image>
                    </ImageView>
                </HBox>
                <!-- Label under the cards, modified by the controller -->
                <Label fx:id="handLabel" text="Hand" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Label>
            </VBox>

            <!-- The deck + label under it -->
            <VBox alignment="CENTER" spacing="10.0">
                <ImageView fx:id="deckImage" fitHeight="130.0" fitWidth="90.0" preserveRatio="true">
                    <image><Image url="@cards/Jack_of_Diamonds.png"/></image>
                </ImageView>
                <!-- Label under the deck, modified by the controller -->
                <Label fx:id="deckLabel" text="Deck" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Label>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
